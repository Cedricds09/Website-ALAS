# ============================================================
# Variables requeridas para arrancar el backend ALAS.
# Copia este archivo como .env y rellena los valores.
# El backend valida estas variables al arrancar; si alguna falta,
# el proceso aborta con código 1.
# ============================================================

# --- Base de datos (SQL Server, autenticación SQL) ---
DB_USER=
DB_PASSWORD=
DB_SERVER=
DB_PORT=
DB_NAME=

# --- Sesión / firma de cookies admin ---
# Cadena aleatoria de al menos 16 chars. Recomendado 32+:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- HTTP server ---
PORT=

# --- Opcionales ---
# Google Maps API key (Places autocomplete + Embed). Restringir por dominio en GCP.
GOOGLE_MAPS_API_KEY=

# Modo de ejecución: production activa flag Secure en cookies de sesión.
NODE_ENV=
